# AEP 环境变量配置模板 — 复制为 .env 并填入实际值
# Day 1.4 requires: BASE_SEPOLIA_RPC, PRIVATE_KEY
# Day 2.1 requires: CAW_API_KEY, CAW_WALLET_ID (see docs/cobo_setup.md)
# Day 3 requires: OPENAI_API_KEY
# Day 3 delivery requires: PINATA_JWT

# === Cobo Agentic Wallet (required for Day 2.1 — pact creation & fund locking) ===
# 1. Create API key: POST /api/v1/principals/provision (see docs/cobo_setup.md)
# 2. Create wallet & fund it with test ETH
CAW_API_KEY=
CAW_WALLET_ID=

# === On-chain (required for Day 1.4 — contract deployment) ===
BASE_SEPOLIA_RPC=
PRIVATE_KEY=

# === AI evaluation (required for Day 3 — LLM dual-track) ===
# Supports OpenAI, DeepSeek, or any OpenAI-compatible API
# DeepSeek: get key from https://platform.deepseek.com/api_keys
# Config in config.yaml: model="deepseek-chat", base_url="https://api.deepseek.com/v1"
OPENAI_API_KEY=

# === IPFS/Pinata (required for Day 3 — result upload) ===
PINATA_JWT=
