# AEP 环境变量配置模板 — 复制为 .env 并填入实际值
# Cobo CAW: CAW_API_KEY, CAW_WALLET_ID (see docs/cobo_setup.md)
# On-chain: RPC_URL (Sepolia), PRIVATE_KEY
# AI: OPENAI_API_KEY (DeepSeek/OpenAI)

# === Cobo Agentic Wallet — Buyer (MPC, paired with CAW App) ===
CAW_API_KEY=
CAW_WALLET_ID=

# === Cobo Agentic Wallet — Provider (custodial/unpaired, auto-approve) ===
PROVIDER_CAW_API_KEY=
PROVIDER_CAW_WALLET_ID=

# === Cobo Agentic Wallet — Sub-Provider (custodial/unpaired) ===
SUB_PROVIDER_CAW_API_KEY=
SUB_PROVIDER_CAW_WALLET_ID=

# === On-chain (contract deployment & reputation updates) ===
SEPOLIA_RPC=https://ethereum-sepolia.publicnode.com
PRIVATE_KEY=

# === AI evaluation (DeepSeek / OpenAI-compatible) ===
OPENAI_API_KEY=

# === IPFS/Pinata (delivery artifact storage) ===
PINATA_JWT=
